SERVICE_NAME=patent-search-service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

ENABLE_AUTH=true
API_TOKEN=

OPENSEARCH_HOST=opensearch-o-00gcv9almneh.escloud.volces.com
OPENSEARCH_PORT=9200
OPENSEARCH_USE_HTTPS=true
OPENSEARCH_USER=admin
OPENSEARCH_PASS=
# Keep the current physical index for local compatibility. Production must use
# a verified read alias only after the v2 cutover checklist has passed.
OPENSEARCH_INDEX=patent_index
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_TIMEOUT_SECONDS=30

# Stage 10 SaaS PatentHub tool adapter.
PATENT_SEARCH_BASE_URL=http://127.0.0.1:8000
PATENT_SEARCH_API_TOKEN=
PATENT_SEARCH_USE_SELF_HOSTED=true
PATENT_SEARCH_PAGE_SIZE_LIMIT=50
PATENT_SEARCH_TIMEOUT_SECONDS=30

# Remote HTTP MCP server authentication.
MCP_ACCESS_TOKEN=

# Optional fallback to external PatentHub when PATENT_SEARCH_USE_SELF_HOSTED=false.
PATENTHUB_BASE_URL=https://www.patenthub.cn
PATENTHUB_API_TOKEN=
